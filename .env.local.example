# ── Frontend (Vite) ──────────────────────────────────────────
# Your Convex deployment URL (printed by `pnpm exec convex dev`).
VITE_CONVEX_URL=

# ── Convex backend env ───────────────────────────────────────
# Set in the Convex dashboard or via:
#   pnpm exec convex env set <NAME> <value>
#
# Convex Auth generates these for you — run `pnpm exec @convex-dev/auth`:
#   JWT_PRIVATE_KEY=...
#   JWKS=...
#   SITE_URL=http://localhost:5173
#
# Google OAuth (required) — https://console.cloud.google.com:
#   AUTH_GOOGLE_ID=...
#   AUTH_GOOGLE_SECRET=...
#
# GitHub OAuth (OPTIONAL — omit to disable the GitHub button) —
# https://github.com/settings/developers:
#   AUTH_GITHUB_ID=...
#   AUTH_GITHUB_SECRET=...
