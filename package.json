{
  "name": "convex-starter",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n convex,vite -c blue,green \"convex dev\" \"vite\"",
    "dev:frontend": "vite",
    "dev:backend": "convex dev",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fix": "eslint . --fix && prettier --write . --log-level warn",
    "knip": "knip",
    "clone": "echo '🚀 Exporting data from production...' && convex export --prod --path .temp-prod-export.zip && echo '📥 Importing data to development...' && convex import .temp-prod-export.zip --replace-all --yes && echo '🧹 Cleaning up...' && rm .temp-prod-export.zip && echo '✅ Data successfully cloned from production to development!'"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@convex-dev/auth": "^0.0.94",
    "@tanstack/react-router": "^1.170.17",
    "convex": "^1.42.1",
    "convex-helpers": "^0.1.120",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@convex-dev/eslint-plugin": "^2.0.0",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/router-plugin": "^1.168.19",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-better-tailwindcss": "^4.6.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "knip": "^6.24.0",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3"
  }
}
