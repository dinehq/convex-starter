{
  "name": "convex-starter",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n convex,vite -c blue,green \"convex dev\" \"vite\"",
    "dev:frontend": "vite",
    "dev:backend": "convex dev",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fix": "prettier --write . --log-level warn && eslint . --fix",
    "knip": "knip",
    "clone": "echo '🚀 Exporting data from production...' && convex export --prod --path .temp-prod-export.zip && echo '📥 Importing data to development...' && convex import .temp-prod-export.zip --replace-all --yes && echo '🧹 Cleaning up...' && rm .temp-prod-export.zip && echo '✅ Data successfully cloned from production to development!'"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@convex-dev/auth": "^0.0.93",
    "@tanstack/react-router": "^1.170.13",
    "convex": "^1.40.0",
    "convex-helpers": "^0.1.118",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@convex-dev/eslint-plugin": "^2.0.0",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/router-plugin": "^1.168.16",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "knip": "^6.16.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16"
  }
}
